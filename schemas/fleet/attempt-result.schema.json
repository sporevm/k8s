{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sporevm.dev/schemas/fleet/attempt-result.schema.json",
  "title": "SporeVM fleet attempt result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runID",
    "bundleDigest",
    "childID",
    "attemptID",
    "agentID",
    "shardID",
    "status",
    "startedAt",
    "finishedAt",
    "timingsMs",
    "terminal"
  ],
  "properties": {
    "runID": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "bundleDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "childID": {
      "type": "integer",
      "minimum": 0
    },
    "attemptID": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "agentID": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "shardID": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "skipped-terminal-exists",
        "platform-mismatch"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "timingsMs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactPull",
        "materialization",
        "resume",
        "guestReady",
        "resultCommit"
      ],
      "properties": {
        "artifactPull": {
          "type": "number",
          "minimum": 0
        },
        "materialization": {
          "type": "number",
          "minimum": 0
        },
        "resume": {
          "type": "number",
          "minimum": 0
        },
        "guestReady": {
          "type": "number",
          "minimum": 0
        },
        "resultCommit": {
          "type": "number",
          "minimum": 0
        },
        "localChild": {
          "type": "number",
          "minimum": 0
        },
        "pullVerify": {
          "type": "number",
          "minimum": 0
        },
        "pullInstallIndexes": {
          "type": "number",
          "minimum": 0
        },
        "pullInstallChunks": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "terminal": {
      "type": "boolean"
    },
    "resultURI": {
      "type": "string",
      "pattern": "^s3://[^/]+/.+\\.json$"
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stdoutBytes": {
          "type": "integer",
          "minimum": 0
        },
        "stderrBytes": {
          "type": "integer",
          "minimum": 0
        },
        "stdoutPreviewBase64": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "stderrPreviewBase64": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "stdoutTruncated": {
          "type": "boolean"
        },
        "stderrTruncated": {
          "type": "boolean"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
